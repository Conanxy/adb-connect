{
  "name": "adb-connect-electron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:1420 && npm run build:native && npm run build:electron && electron .",
    "build": "npm run build:native && tsc -p tsconfig.json && vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/rename-electron-output.cjs",
    "build:native": "cargo build --manifest-path native-adb/Cargo.toml",
    "test:native": "cargo test --manifest-path native-adb/Cargo.toml"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "wait-on": "^8.0.1"
  }
}
