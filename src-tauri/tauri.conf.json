{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ADB Connect",
  "version": "0.1.0",
  "identifier": "com.fang.adb-connect",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ADB Connect",
        "width": 1120,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["binaries/*"],
    "icon": []
  }
}
